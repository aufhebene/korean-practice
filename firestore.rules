rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.email is string
                    && request.resource.data.name is string;
      // email 변경은 금지. fcmTokens, reminder 등 일반 필드는 자유롭게 update 가능
      allow update: if isOwner(uid)
                    && (!('email' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isOwner(uid);

      match /vocabularyProgress/{itemId} {
        allow read, write: if isOwner(uid);
      }

      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(uid);
      }

      match /studySessions/{sessionId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.score <= request.resource.data.total
                      && request.resource.data.score >= 0
                      && request.resource.data.items.size() <= 100;
        allow update, delete: if false;
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}
